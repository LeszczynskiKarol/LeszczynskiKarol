function check_user_access_shortcode($atts, $content = null) {
    $atts = shortcode_atts(array(
        'user_id' => '0',
    ), $atts);

    $current_user_id = get_current_user_id();

    if ($current_user_id == $atts['user_id']) {
        return do_shortcode($content);
    }

    return ''; // Nie wyświetlaj nic, jeśli użytkownik nie ma dostępu
}
add_shortcode('user_access', 'check_user_access_shortcode');
function sprawdz_dostep_do_strony() {
    if (is_singular('page')) { // Sprawdź, czy jesteśmy na stronie
        global $post;
        $przypisany_uzytkownik_id = get_post_meta($post->ID, 'przypisany_uzytkownik_id', true);

        // Sprawdź, czy zalogowany użytkownik jest tym samym, który jest przypisany do strony
        if (!empty($przypisany_uzytkownik_id)) {
            $current_user_id = get_current_user_id();

            if (!is_user_logged_in() || ($current_user_id != $przypisany_uzytkownik_id)) {
                wp_redirect(home_url());
                exit;
            }
        }
    }
}
add_action('template_redirect', 'sprawdz_dostep_do_strony');

function restrict_post_to_author() {
    if (is_single()) { // Sprawdza, czy jesteśmy na stronie pojedynczego posta
        global $post;
        $current_user_id = get_current_user_id();

        // Sprawdza, czy zalogowany użytkownik jest autorem posta
        if ($post->post_author != $current_user_id) {
            wp_redirect(home_url());
            exit;
        }
    }
}
add_action('template_redirect', 'restrict_post_to_author');

function yoast_seo_noindex_nofollow_for_clients() {
    if (is_user_logged_in() && !current_user_can('administrator')) {
        // Dodaj filtry Yoast SEO do ustawienia tagów robots na noindex i nofollow
        add_filter('wpseo_robots', function() { return 'noindex, nofollow'; });
        
        // Opcjonalnie, jeśli chcesz ustawić noindex dla całej strony (w tym dla linków kanonicznych itp.)
        add_filter('wpseo_canonical', '__return_false');
    }
}
