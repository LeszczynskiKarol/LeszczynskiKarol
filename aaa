function switch_menu_by_login_status($args) {
    // Określ lokalizację menu, którą chcesz modyfikować
    $theme_location = 'primary'; // Możesz zmienić na właściwą lokalizację menu

    if ($args['theme_location'] === $theme_location) {
        if (is_user_logged_in()) {
            // Zdefiniuj ID Twojego menu dla zalogowanych użytkowników
            $logged_in_menu = wp_get_nav_menu_object('login')->term_id; // Zastąp 'Logged In Menu Name' nazwą Twojego menu
            if ($logged_in_menu) {
                $args['menu'] = $logged_in_menu;
            }
        } else {
            // Zdefiniuj ID Twojego menu dla niezalogowanych użytkowników
            $logged_out_menu = wp_get_nav_menu_object('logout')->term_id; // Zastąp 'Logged Out Menu Name' nazwą Twojego menu
            if ($logged_out_menu) {
                $args['menu'] = $logged_out_menu;
            }
        }
    }

    return $args;
}
add_filter('wp_nav_menu_args', 'switch_menu_by_login_status');

function custom_redirect_logged_in_users() {
    // Sprawdza, czy użytkownik jest zalogowany
    if (is_user_logged_in()) {
        // Pobiera aktualny URL
        $current_url = home_url(add_query_arg(array(), $wp->request));
        // Określa URL, na który mają zostać przekierowani zalogowani użytkownicy
        $account_page_url = wc_get_page_permalink('myaccount');

        // Sprawdza, czy aktualny URL zawiera '/login/' lub '/registration/'
        if (strpos($current_url, '/login/') !== false || strpos($current_url, '/registration/') !== false) {
            // Przekierowuje zalogowanych użytkowników na stronę '/moje-konto/'
            wp_redirect($account_page_url);
            exit;
        }
    }
}
add_action('template_redirect', 'custom_redirect_logged_in_users');

function custom_redirect_logged_in_users_from_login_and_registration() {
    if (is_user_logged_in() && !is_admin()) {
        global $wp;
        $current_url = home_url(add_query_arg(array(), $wp->request));
        $account_page_url = wc_get_page_permalink('myaccount');
        
        if (strpos($current_url, '/login/') !== false || strpos($current_url, '/registration/') !== false) {
            wp_redirect($account_page_url);
            exit;
        }
    }
}
add_action('template_redirect', 'custom_redirect_logged_in_users_from_login_and_registration');



function custom_handle_user_registration($customer_id) {
    $user = get_userdata($customer_id);
    $token = md5(uniqid($user->user_login, true)); // Generuj unikalny token
    add_user_meta($customer_id, 'account_activation_token', $token); // Zapisz token w metadanych użytkownika

    // Przygotuj i wyślij e-mail weryfikacyjny
    $activation_link = add_query_arg(array('key' => $token, 'user' => $customer_id), get_permalink(get_option('woocommerce_myaccount_page_id')) . '?action=activate');
    $to = $user->user_email;
    $subject = 'Aktywuj swoje konto';
    $body = 'Kliknij ten link, aby aktywować swoje konto: ' . $activation_link;
    wp_mail($to, $subject, $body);

    // Usuń automatyczne logowanie po rejestracji
    remove_action('woocommerce_registration_redirect', 'wc_registration_redirect');
}

add_filter('woocommerce_registration_auth_new_customer', '__return_false');

function custom_woocommerce_prevent_autologin_after_registration($redirect, $user) {
    // Nie loguj automatycznie nowych użytkowników i nie przekierowuj ich na stronę 'Moje konto'
    if (get_transient('custom_registration_attempted')) {
        delete_transient('custom_registration_attempted');
        // Zwróć URL do strony logowania z komunikatem
        $redirect = add_query_arg('registered', 'yes', wc_get_page_permalink('myaccount'));
    }
    return $redirect;
}
add_filter('woocommerce_registration_redirect', 'custom_woocommerce_prevent_autologin_after_registration', 10, 2);

