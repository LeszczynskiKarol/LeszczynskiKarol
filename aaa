add_filter('woocommerce_registration_redirect', 'custom_registration_redirect_prevent', 10, 1);
function custom_registration_redirect_prevent($redirect) {
    // Usuń domyślne przekierowanie po rejestracji
    if (isset($_POST['register']) && wp_verify_nonce($_POST['woocommerce-register-nonce'], 'woocommerce-register')) {
        // Dodaj niestandardowy komunikat po próbie rejestracji
        wc_add_notice(__('Sprawdź swoją skrzynkę e-mail, aby aktywować konto.', 'woocommerce'), 'success');
        
        // Zwróć oryginalny URL, aby zatrzymać użytkownika na bieżącej stronie
        return wc_get_page_permalink('myaccount') . '?action=register';
    }
    return $redirect;
}


// Dostosowanie funkcji aktywacji konta
function custom_woocommerce_activate_account() {
    if (is_page() && isset($_GET['action']) && $_GET['action'] === 'activate' && !empty($_GET['key']) && !empty($_GET['user'])) {
        $user_id = intval($_GET['user']);
        $token = get_user_meta($user_id, 'account_activation_token', true);

        if ($_GET['key'] === $token) {
            delete_user_meta($user_id, 'account_activation_token'); // Usuń token

            // Automatyczne logowanie użytkownika po aktywacji
            wp_set_current_user($user_id);
            wp_set_auth_cookie($user_id);

            // Dodaj komunikat o pomyślnej aktywacji
            wc_add_notice(__('Twoje konto zostało pomyślnie aktywowane. Witamy!', 'woocommerce'), 'success');

            // Przekieruj na stronę 'Moje konto'
            wp_redirect(wc_get_page_permalink('myaccount'));
            exit;
        } else {
            wc_add_notice(__('Błąd aktywacji konta. Link aktywacyjny może być nieprawidłowy lub wygasł.', 'woocommerce'), 'error');
            wp_redirect(wc_get_page_permalink('myaccount'));
            exit;
        }
    }
}
add_action('template_redirect', 'custom_woocommerce_activate_account');

// Wyświetlenie komunikatu o pomyślnej aktywacji konta
