function display_last_invoice_summary() {
    $user_id = get_current_user_id();
    $args = array(
        'author' => $user_id,
        'post_type' => 'invoice', // Zmieniono na 'invoice', zakładając, że to jest typ postu dla faktur
        'posts_per_page' => 2, // Zmieniono na 5, aby wyświetlić ostatnie 5 faktur
        'orderby' => 'date',
        'order' => 'DESC'
    );

    $invoices = new WP_Query($args);

    if ($invoices->have_posts()) {
        echo '<table style="width:100%;">';
        echo '<tr><th>Data</th><th>Numer</th><th>Wartość</th><th>PDF</th></tr>';

        while ($invoices->have_posts()) {
            $invoices->the_post();
            $invoice_id = get_the_ID();
            $invoice_number = get_post_meta($invoice_id, 'invoice_number', true); // Załóżmy, że numer faktury jest przechowywany w meta polu 'invoice_number'
            $invoice_value = get_post_meta($invoice_id, 'invoice_value', true); // Załóżmy, że wartość faktury jest przechowywana w meta polu 'invoice_value'
            $invoice_pdf_url = get_post_meta($invoice_id, 'invoice_pdf_url', true); // Załóżmy, że URL do PDF faktury jest przechowywany w meta polu 'invoice_pdf_url'

            echo '<tr>';
            echo '<td>' . get_the_date('Y-m-d') . '</td>';
            echo '<td>' . esc_html($invoice_number) . '</td>';
            echo '<td>' . esc_html($invoice_value) . '</td>';
            echo '<td><a href="' . esc_url($invoice_pdf_url) . '" target="_blank">Pobierz PDF</a></td>';
            echo '</tr>';
        }

        echo '</table>';
        wp_reset_postdata();
    } else {
        echo '<p>Nie masz jeszcze żadnych faktur.</p>';
    }
}


function plural_form($number) {
    $cases = [2, 0, 1, 1, 1, 2];
    $titles = ['tekst', 'teksty', 'tekstów'];
    $case = ($number % 100 > 4 && $number % 100 < 20) ? 2 : $cases[min($number % 10, 5)];
    return $titles[$case];
}
