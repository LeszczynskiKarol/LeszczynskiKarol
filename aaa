function smart_copy_display_user_invoices() {
    $user_id = get_current_user_id();

    $args = [
        'post_type' => 'invoice',
        'posts_per_page' => -1,
        'orderby' => 'date',
        'order' => 'DESC',
        'author' => $user_id,
    ];

    $query = new WP_Query($args);

    
    echo '<table style="width:100%; table-layout: fixed;">';
    echo '<thead>';
    echo '<tr><th width="5%">' . __('Nr', 'text-domain') . '</th><th width="15%">' . __('Data', 'text-domain') . '</th><th width="20%">' . __('Forma rozliczenia', 'text-domain') . '</th><th width="20%">' . __('Liczba tekstów', 'text-domain') . '</th><th width="15%">' . __('Liczba znaków', 'text-domain') . '</th><th width="15%">' . __('Cena', 'text-domain') . '</th><th width="10%">' . __('PDF', 'text-domain') . '</th></tr>';
    echo '</thead>';
    echo '<tbody>';

    if ($query->have_posts()) {
        while ($query->have_posts()) {
            $query->the_post();
            $post_id = get_the_ID();
            $pdf_url = get_post_meta($post_id, 'post_pdf_url', true);
            $number_of_texts = get_post_meta($post_id, 'number_of_texts', true);
            $number_of_characters = get_post_meta($post_id, 'number_of_characters', true);
            $payform = get_post_meta($post_id, 'payform', true);
            $price = get_post_meta($post_id, 'price', true); // Pobieranie ceny

            echo '<tr>';
            echo '<td>' . esc_html($post_id) . '</td>';
            echo '<td>' . get_the_date('Y-m-d') . '</td>';
            echo '<td>' . esc_html($payform) . '</td>';
            echo '<td>' . esc_html($number_of_texts) . '</td>';
            echo '<td>' . esc_html($number_of_characters) . '</td>';
            echo '<td>' . esc_html($price) . ' zł</td>'; // Wyświetlanie ceny
            echo '<td>' . (!empty($pdf_url) ? '<a href="/download.php?type=invoices&file=' . basename($pdf_url) . '" target="_blank">' . __('Pobierz PDF', 'text-domain') . '</a>' : __('Brak PDF', 'text-domain')) . '</td>';
            echo '</tr>';
        }
        wp_reset_postdata();
    } else {
        echo '<tr><td colspan="7">Nie znaleziono faktur.</td></tr>';
    }

    echo '</tbody></table>';
}




