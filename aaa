function generate_and_save_post_pdf($post_id) {
    if (defined('DOING_AUTOSAVE') && DOING_AUTOSAVE) return;
    if (wp_is_post_revision($post_id)) return;

    // Określamy ścieżkę i URL dla zapisu PDF
    $pdf_storage_path = '/home/virt102760/domains/smart-copy.ai/public_html/pdf/';
    $pdf_public_url_base = 'https://smart-copy.ai/pdf/'; // Tutaj należy podać właściwy URL

    $post = get_post($post_id);
    $content = apply_filters('the_content', $post->post_content);

    $dompdf = new Dompdf();
    $dompdf->loadHtml($content);
    $dompdf->setPaper('A4', 'portrait');
    $dompdf->render();

    // Tworzymy nazwę pliku PDF
    $pdf_file_name = 'post-' . $post_id . '.pdf';
    $pdf_path = $pdf_storage_path . $pdf_file_name;

    // Zapisujemy wygenerowany PDF do pliku
    file_put_contents($pdf_path, $dompdf->output());

    // Budujemy publiczny URL do PDF
    $pdf_url = $pdf_public_url_base . $pdf_file_name;

    // Aktualizujemy metadane posta o URL do PDF
    update_post_meta($post_id, 'post_pdf_url', $pdf_url);
}

