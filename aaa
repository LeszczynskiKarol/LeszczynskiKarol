            echo '<tr>';
            echo '<td>' . get_the_date('Y-m-d H:i:s') . '</td>';
            // Temat jako link
            echo '<td>' . esc_html($temat) . '</td>';
            echo '<td>' . esc_html($dlugosc) . '</td>';
            echo '<td>' . wc_price($cena) . '</td>';
            echo '</tr>';
        }

        echo '</table>';
        wp_reset_postdata();
    } else {
        echo '<p>' . __('Nie masz jeszcze żadnych zamówień.', 'text-domain') . '</p>';
    }
}

function display_user_statistics_in_dashboard() {
    if (function_exists('is_account_page') && is_account_page() && !is_wc_endpoint_url()) {
        $user_id = get_current_user_id();

        // Query for all posts by the user
        $args_all_posts = [
            'author' => $user_id,
            'post_type' => 'post',
            'posts_per_page' => -1,
        ];
        $query_all_posts = new WP_Query($args_all_posts);
        $total_posts = $query_all_posts->found_posts;

        // Query for posts published yesterday
        $yesterday = new DateTime('yesterday');
        $args_yesterday_posts = [
            'author' => $user_id,
            'post_type' => 'post',
            'posts_per_page' => -1,
            'date_query' => [
                [
                    'year' => $yesterday->format('Y'),
                    'month' => $yesterday->format('m'),
                    'day' => $yesterday->format('d'),
                ],
            ],
        ];
        $query_yesterday_posts = new WP_Query($args_yesterday_posts);
        $yesterday_posts_count = $query_yesterday_posts->found_posts;

        $total_characters = 0;
        $total_value = 0;
        $last_post_date = null;

        while ($query_all_posts->have_posts()) {
            $query_all_posts->the_post();
            $characters = get_post_meta(get_the_ID(), 'Liczba znaków', true);
            $total_characters += intval($characters);
            $price = get_post_meta(get_the_ID(), 'Cena', true);
            $total_value += floatval($price);
            if (is_null($last_post_date) || strtotime(get_the_date('Y-m-d')) > strtotime($last_post_date)) {
                $last_post_date = get_the_date('Y-m-d');
            }
        }
        wp_reset_postdata();

        $user_info = get_userdata($user_id);
        $registration_date = date('Y-m-d', strtotime($user_info->user_registered));
        $today = new DateTime();
        $last_post_datetime = is_null($last_post_date) ? null : new DateTime($last_post_date);
        $days_since_last_post = $last_post_datetime ? $today->diff($last_post_datetime)->days : null;

        $message_2_to_5_days = "Od Twojego ostatniego tekstu na Smart Copy minęły <b>{$days_since_last_post}</b> dni. Najwyższy czas na kolejny! ✍️";
        $message_5_to_14_days = "Minęło już <b>{$days_since_last_post}</b> dni od Twojej ostatniej aktywności 🤔 na Smart Copy. Jeśli potrzebujesz treści, wybierz moduł i wygeneruj w 2 min 🙂";
        $message_above_14_days = "Nie widać Cię już <b>{$days_since_last_post}</b> dni 😟. Pewnie masz sporo na głowie, ale pamiętaj, że Smart Copy czeka na Ciebie 24 godziny na dobę 🤗";

        $last_post_message = "";
        if ($yesterday_posts_count > 0) {
            $yesterday_text = plural_form($yesterday_posts_count);
            $last_post_message .= "<b>{$yesterday_posts_count} {$yesterday_text}</b> – to Twój wczorajszy bilans. Dzisiaj będzie więcej? 🤗";
        }
        if (is_null($last_post_date)) {
            $last_post_message = "Nie masz jeszcze żadnych tekstów. Wybierz moduł i <b>wygeneruj pierwsze treści</b> już teraz! ✍";
        } elseif ($today_posts_count > 0) {
            $last_post_message = "Masz już <b>{$today_posts_count}</b> tekst(ów) dzisiaj na koncie. Dobra robota! Kontynuujmy tę passę! 🚀";
        } elseif ($days_since_last_post >= 2 && $days_since_last_post <= 5) {
            $last_post_message = $message_2_to_5_days;
        } elseif ($days_since_last_post > 5 && $days_since_last_post <= 14) {
            $last_post_message = $message_5_to_14_days;
        } elseif ($days_since_last_post > 14) {
            $last_post_message = $message_above_14_days;
        }
        echo '<div class="user-stats">';
        if (!empty($last_post_message)) {
            echo "<p>$last_post_message</p>";
        }
        echo '</div>';

        // Wyświetlanie komunikatu i statystyk
        echo '<div class="stats" style="font-family: Arial, sans-serif;">';
        echo '<ul style="list-style: none;">'; // Usunięcie bullet points
        echo '<li><i class="fas fa-clock" style="color: #44d9f9;"></i> ' . $last_post_message . '</li>';
		echo '<li><i class="fas fa-calendar-alt" style="color: #44d9f9;"></i> Jesteś na Smart Copy od: ' . $registration_date . '</li>';
        echo '<li><i class="fas fa-file-alt" style="color: #44d9f9;"></i> Liczba dotychczas wygenerowanych tekstów: ' . $total_posts . '</li>';
        echo '<li><i class="fas fa-text-width" style="color: #44d9f9;"></i> Łączna liczba znaków: ' . $total_characters . '</li>';
        echo '<li><i class="fas fa-money-bill-wave" style="color: #44d9f9;"></i> Wartość wszystkich Twoich zamówień: ' . wc_price($total_value) . '</li>';
        echo '</ul>';
        echo '</div>';
    }
}



function handle_incoming_invoices(WP_REST_Request $request) {
    $data = $request->get_json_params();
    $invoice_data = isset($data['meta']) ? $data['meta'] : [];

    // Tworzenie lub aktualizacja postu faktury
    $post_id = wp_insert_post([
        'post_type' => 'invoice',
        'post_title' => sanitize_text_field($data['title']),
        'post_status' => 'publish',
        'author' => isset($data['author']) ? intval($data['author']) : get_current_user_id(),
        'meta_input' => [
            'number_of_texts' => isset($invoice_data['number_of_texts']) ? sanitize_text_field($invoice_data['number_of_texts']) : '',
            'number_of_characters' => isset($invoice_data['number_of_characters']) ? sanitize_text_field($invoice_data['number_of_characters']) : '',
            'payform' => isset($invoice_data['payform']) ? sanitize_text_field($invoice_data['payform']) : '',
            'price' => isset($invoice_data['price']) ? sanitize_text_field($invoice_data['price']) : '', // Dodanie obsługi 'price'
        ],
    ]);

    if (is_wp_error($post_id)) {
        return new WP_Error('invoice_creation_failed', 'Nie udało się utworzyć faktury.', ['status' => 500]);
    }

    return new WP_REST_Response(['message' => 'Faktura została pomyślnie utworzona.', 'post_id' => $post_id], 200);
}









