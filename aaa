// Dodaj pole z tokenem aktywacyjnym do użytkownika podczas rejestracji
function custom_woocommerce_add_registration_token($user_id) {
    if (isset($_POST['password']) && isset($_POST['password2'])) {
        // Sprawdź, czy hasła się zgadzają
        if ($_POST['password'] !== $_POST['password2']) {
            // Usuń utworzonego użytkownika, ponieważ hasła się nie zgadzają
            require_once(ABSPATH.'wp-admin/includes/user.php');
            wp_delete_user($user_id);

            // Dodaj błąd, który zostanie wyświetlony użytkownikowi
            wc_add_notice(__('Błąd: Hasła nie są identyczne. Proszę spróbować ponownie.', 'woocommerce'), 'error');

            // Przekieruj z powrotem na stronę rejestracji
            wp_redirect(get_permalink(woocommerce_get_page_id('myaccount')) . '?action=register');
            exit;
        }
    }

    $user = get_userdata($user_id);
    $token = md5(uniqid($user->user_login, true)); // Generuj unikalny token
    add_user_meta($user_id, 'account_activation_token', $token); // Zapisz token w metadanych użytkownika

    // Przygotuj i wyślij e-mail weryfikacyjny
    $activation_link = add_query_arg(array('key' => $token, 'user' => $user_id), get_permalink(get_option('woocommerce_myaccount_page_id')) . '?action=activate');
    $to = $user->user_email;
    $subject = 'Aktywuj swoje konto';
    $body = 'Kliknij ten link, aby aktywować swoje konto: ' . $activation_link;
    wp_mail($to, $subject, $body);
}
