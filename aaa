    );

    $orders = new WP_Query($args);

    if ($orders->have_posts()) {
        echo '<table style="width:100%;">';
        echo '<tr><th>Data</th><th>Temat</th><th>Długość</th><th>Cena</th></tr>';

        while ($orders->have_posts()) {
